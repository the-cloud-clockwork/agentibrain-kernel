# Sample overlay — agentibrain-brain-api (prod).
tpl:
  global:
    environment: prod
  app:
    image:
      tag: latest
  externalSecret:                                  # nosecret
    enabled: true                                  # nosecret
    storeName: <your-secret-store>                 # nosecret
    secretPath: <your-secret-path>/agentibrain-reader   # nosecret
    targetSecretName: agentibrain-reader-secrets   # nosecret
  extraVolumes:
    - name: nfs-vault
      nfs:
        server: <your-host>
        path: <your-vault-path>
  extraVolumeMounts:
    - name: nfs-vault
      mountPath: /vault
