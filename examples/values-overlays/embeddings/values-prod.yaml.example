# Sample overlay — agentibrain-embeddings (prod).
tpl:
  global:
    environment: prod
  app:
    image:
      tag: latest
  env:
    variables:
      LLM_API_BASE: <your-embeddings-api-base>
      LLM_EMBED_MODEL: text-embedding-3-small
      POSTGRES_URL: postgresql://<user>:<pass>@<host>:5432/<db>
  externalSecret:                                  # nosecret
    enabled: true                                  # nosecret
    storeName: <your-secret-store>                 # nosecret
    secretPath: <your-secret-path>/agentibrain-embeddings   # nosecret
    targetSecretName: agentibrain-embeddings-secrets   # nosecret
