# Sample overlay — agentibrain-brain-cron (singleton, cluster-wide).
# One CronJob set + one amygdala Deployment per cluster.
tpl:
  global:
    environment: dev      # cron tracks dev tag for fast iteration on tick code
  app:
    image:
      tag: dev
  env:
    variables:
      INFERENCE_URL: http://<your-llm-gateway>.<your-namespace>.svc:4000
      BRAIN_CLASSIFY_MODEL: <your-classify-model>
      BRAIN_BRIEF_MODEL: <your-brief-model>
      EMBEDDINGS_URL: http://agentibrain-embeddings.<your-namespace>.svc:8080
      OBSIDIAN_READER_URL: http://agentibrain-obsidian-reader.<your-namespace>.svc:8080
      REDIS_URL: redis://<your-redis-host>:6379/0
  externalSecret:                                  # nosecret
    enabled: true                                  # nosecret
    storeName: <your-secret-store>                 # nosecret
    secretPath: <your-secret-path>/agentibrain-cron   # nosecret
    targetSecretName: agentibrain-cron-secrets     # nosecret
    data:                                          # nosecret
      - secretKey: INFERENCE_API_KEY               # nosecret
        remoteRef:                                 # nosecret
          key: <your-secret-path>/brain-inference  # nosecret
          property: INFERENCE_API_KEY              # nosecret
  extraVolumes:
    - name: nfs-vault
      nfs:
        server: <your-host>
        path: <your-vault-path>
  extraVolumeMounts:
    - name: nfs-vault
      mountPath: /vault
