# Sample overlay — agentibrain-mcp (prod).
# Layered on top of agentibrain-kernel/helm/mcp/values.yaml.
tpl:
  global:
    environment: prod
  app:
    image:
      tag: latest
  env:
    variables:
      KB_ROUTER_URL: http://agentibrain-kb-router.<your-namespace>.svc:8080
      OBSIDIAN_READER_URL: http://agentibrain-obsidian-reader.<your-namespace>.svc:8080
      EMBEDDINGS_URL: http://agentibrain-embeddings.<your-namespace>.svc:8080
      INFERENCE_URL: http://<your-llm-gateway>.<your-namespace>.svc:4000
      BRAIN_BRIEF_MODEL: <your-brief-model>

  externalSecret:                                  # nosecret
    enabled: true                                  # nosecret
    storeName: <your-secret-store>                 # nosecret
    secretPath: <your-secret-path>/agentibrain-mcp # nosecret
    targetSecretName: agentibrain-mcp-secrets      # nosecret
    data:                                          # nosecret
      - secretKey: MCP_PROXY_API_KEY               # nosecret
        remoteRef:                                 # nosecret
          key: <your-secret-path>/agentibrain-mcp  # nosecret
          property: MCP_PROXY_API_KEY              # nosecret
      - secretKey: INFERENCE_API_KEY               # nosecret
        remoteRef:                                 # nosecret
          key: <your-secret-path>/brain-inference  # nosecret
          property: INFERENCE_API_KEY              # nosecret
      - secretKey: OBSIDIAN_READER_TOKEN           # nosecret
        remoteRef:                                 # nosecret
          key: <your-secret-path>/agentibrain-router    # nosecret
          property: OBSIDIAN_READER_TOKEN          # nosecret
      - secretKey: EMBEDDINGS_API_KEY              # nosecret
        remoteRef:                                 # nosecret
          key: <your-secret-path>/agentibrain-router    # nosecret
          property: EMBEDDINGS_API_KEY             # nosecret
