    {
      "id": 109,
      "title": "Signals: collected vs written vs tombstoned (7d)",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "description": "Collected = everything in arcs. Written = survived sweep (broadcast). Tombstoned = swept as stale. Gap between collected and written is Tier 2 self-healing working.",
      "gridPos": {
        "x": 9,
        "y": 14,
        "w": 15,
        "h": 8
      },
      "targets": [
        {
          "format": 1,
          "refId": "A",
          "rawSql": "SELECT timestamp AS time, signals_collected AS collected, signals_written AS written, signals_tombstoned_stale AS tombstoned_stale, signals_tombstoned_cleared AS tombstoned_cleared FROM brain.tick_health WHERE timestamp > now()-INTERVAL 7 DAY ORDER BY timestamp"
        }
      ]
    },
    {
