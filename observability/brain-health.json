      "description": "Messages flowing through the bus right now.",
      "gridPos": {
        "x": 12,
        "y": 31,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "format": 1,
          "rawSql": "SELECT SpanAttributes['source'] AS Source, SpanAttributes['channel'] AS Channel, SpanAttributes['severity'] AS Sev, SpanAttributes['message_id'] AS MsgID, count() AS Deliveries, max(Timestamp) AS LastSeen FROM otel.otel_traces WHERE ServiceName='agentihooks' AND SpanName='brain.delivery' AND Timestamp > now()-INTERVAL 30 MINUTE GROUP BY Source, Channel, Sev, MsgID ORDER BY LastSeen DESC LIMIT 20",
          "refId": "A"
        }
      ]
