      "targets": [
        {
          "format": 1,
          "refId": "A",
          "rawSql": "SELECT toStartOfHour(timestamp) AS time, quantile(0.5)(total_ms)/1000 AS p50, quantile(0.95)(total_ms)/1000 AS p95 FROM brain.tick_health WHERE timestamp > now()-INTERVAL 7 DAY GROUP BY time ORDER BY time"
