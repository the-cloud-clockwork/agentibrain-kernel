    {
      "id": 111,
      "title": "Injects / hour",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "description": "Actual broadcast injections into agent contexts \u2014 the cost graph.",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "format": 1,
          "rawSql": "SELECT toStartOfMinute(Timestamp) AS time, count() AS injects FROM otel.otel_traces WHERE ServiceName='agentihooks' AND SpanName='brain.delivery' AND SpanAttributes['skipped']='false' AND Timestamp > now()-INTERVAL 6 HOUR GROUP BY time ORDER BY time",
          "refId": "A"
        }
      ]
    },
    {
      "id": 112,
      "title": "Skip reasons (stacked)",
      "type": "timeseries",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "description": "Proof that cadence controls are working \u2014 dedup/throttle/cap suppressions.",
      "gridPos": {
        "x": 12,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "format": 1,
          "refId": "dedup",
          "rawSql": "SELECT toStartOfMinute(Timestamp) AS time, count() AS dedup FROM otel.otel_traces WHERE ServiceName='agentihooks' AND SpanName='brain.delivery' AND SpanAttributes['skip_reason']='dedup' AND Timestamp > now()-INTERVAL 6 HOUR GROUP BY time ORDER BY time"
        },
        {
          "format": 1,
          "refId": "throttle",
          "rawSql": "SELECT toStartOfMinute(Timestamp) AS time, count() AS throttle FROM otel.otel_traces WHERE ServiceName='agentihooks' AND SpanName='brain.delivery' AND SpanAttributes['skip_reason']='throttle' AND Timestamp > now()-INTERVAL 6 HOUR GROUP BY time ORDER BY time"
        },
        {
          "format": 1,
          "refId": "cap",
          "rawSql": "SELECT toStartOfMinute(Timestamp) AS time, count() AS cap FROM otel.otel_traces WHERE ServiceName='agentihooks' AND SpanName='brain.delivery' AND SpanAttributes['skip_reason']='cap' AND Timestamp > now()-INTERVAL 6 HOUR GROUP BY time ORDER BY time"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal"
            },
            "lineWidth": 1
          }
        }
      }
    },
    {
      "id": 113,
      "title": "Bytes injected \u2014 top sessions (1h)",
      "type": "table",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "description": "Which sessions are paying the broadcast cost.",
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "format": 1,
          "rawSql": "SELECT SpanAttributes['session_id'] AS Session, count() AS Injects, sum(toInt64OrZero(SpanAttributes['bytes'])) AS Bytes FROM otel.otel_traces WHERE ServiceName='agentihooks' AND SpanName='brain.delivery' AND SpanAttributes['skipped']='false' AND Timestamp > now()-INTERVAL 1 HOUR GROUP BY Session ORDER BY Bytes DESC LIMIT 10",
          "refId": "A"
        }
      ]
    },
    {
      "id": 114,
      "title": "Active broadcasts (live)",
      "type": "table",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
