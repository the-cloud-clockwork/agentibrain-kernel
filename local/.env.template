# agentibrain-kernel — local deploy environment.
# Copy to ../.env (project root) via local/bootstrap.sh, or by hand.
# All values have safe defaults except where noted.

# ===== Required =====
# Postgres connection. Default points at the bundled postgres container.
POSTGRES_URL=postgresql://brain:brain@postgres:5432/brain

# Embedding provider key. Without this, the embeddings service refuses to
# embed; semantic search returns empty. kb-router + tick still work fine
# without embeddings — semantic features just degrade.
LLM_API_KEY=

# Bearer tokens. bootstrap.sh fills these with `openssl rand -hex 32`.
KB_ROUTER_TOKEN=__GENERATE__
VAULT_READER_TOKENS=__GENERATE__

# ===== Optional: AI tick =====
# Inference endpoint (OpenAI-compatible /v1/chat/completions). Empty disables
# the AI phase of the tick — deterministic features still run.
# Examples:
#   - Ollama overlay:        http://ollama:11434/v1   (use compose.ollama.yml)
#   - LiteLLM proxy:         http://your-litellm/v1
#   - OpenAI direct:         https://api.openai.com/v1  (LLM_API_KEY = OpenAI)
#   - Anthropic via LiteLLM: http://your-litellm/v1
INFERENCE_URL=
# Bearer token for the inference gateway. Empty = no Authorization header
# (e.g. Ollama, trusted-LAN inference-gateway). For LiteLLM / OpenAI this is
# the virtual key / API key.
INFERENCE_API_KEY=
# Brain model names. Standard OpenAI `model` field. Wire your gateway to
# alias these at whatever underlying model you want. See docs/GATEWAY-CONTRACT.md.
BRAIN_CLASSIFY_MODEL=brain-classify
BRAIN_BRIEF_MODEL=brain-brief

# ===== Optional: vault =====
# Path on host. ./vault is auto-scaffolded by bootstrap.sh. Point at your
# existing Obsidian vault to use real notes.
VAULT_ROOT_HOST=./vault

# ===== Optional: embeddings model =====
# Default uses OpenAI text-embedding-3-small (1536 dims, matches schema).
# Override LLM_API_BASE for a different OpenAI-compatible host.
LLM_EMBED_MODEL=text-embedding-3-small
LLM_API_BASE=

# ===== Optional: ports (override on collision) =====
# Defaults: 5432 (postgres), 6379 (redis), 8101 (obsidian-reader),
# 8102 (embeddings), 8103 (kb-router), 8104 (mcp).
# PORT_POSTGRES=5432
# PORT_REDIS=6379
# PORT_OBSIDIAN_READER=8101
# PORT_EMBEDDINGS=8102
# PORT_KB_ROUTER=8103
# PORT_MCP=8104

# ===== Optional: logging =====
LOG_LEVEL=INFO

# ===== Optional: tick scheduling =====
# Compose doesn't have native cron — tick-cron uses a sleep loop.
# Default: 7200 (2 hours). Lower for dev/testing.
TICK_INTERVAL_SECONDS=7200

# ===== Optional: amygdala (event consumer) =====
# AMYGDALA_STREAMS=events:health,events:host,events:deploy,events:system,events:brain
# AMYGDALA_CONSUMER=amygdala-local

# ===== Optional: brain-keeper decay knobs =====
# BRAIN_DECAY_START_DAYS=2
# BRAIN_DECAY_INTERVAL_DAYS=2
# BRAIN_STALE_SIGNAL_DAYS=3

# ===== Optional: artifact store =====
# Set if you also run the antoncore artifact-store and want kb-router to push
# inbound markdown there. Empty = disabled.
ARTIFACT_STORE_URL=
ARTIFACT_STORE_KEY=

# ===== Optional: MCP =====
# MCP_PROXY_API_KEY=
