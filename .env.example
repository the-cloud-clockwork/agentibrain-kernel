# agentibrain-kernel — local deploy environment.
# Copy to ../.env (project root) via local/bootstrap.sh, or by hand.

# ===== Required =====
# Explicit Postgres vars prevent host shell environment from bleeding in
# (e.g. POSTGRES_PASSWORD set to a prod RDS value on the operator's machine).
POSTGRES_USER=brain
POSTGRES_PASSWORD=brain
POSTGRES_DB=brain
POSTGRES_URL=postgresql://brain:brain@postgres:5432/brain

# Embedding provider key. Without this, semantic search returns empty.
# brain-api + tick still work — semantic features just degrade.
LLM_API_KEY=

# Bearer tokens. bootstrap.sh replaces <generated-by-bootstrap> with random hex.
KB_ROUTER_TOKEN=<generated-by-bootstrap>
MCP_PROXY_API_KEY=<generated-by-bootstrap>
EMBEDDINGS_API_KEYS=<generated-by-bootstrap>
# Same value as above — bootstrap.sh aligns these. Consumers (brain-api,
# tick-cron, mcp) use the singular form when calling embeddings.
EMBEDDINGS_API_KEY=<generated-by-bootstrap>

# ===== Optional: AI tick =====
# OpenAI-compatible /v1/chat/completions endpoint. Empty = deterministic only.
# Examples:
#   - Ollama overlay:  http://ollama:11434/v1  (use compose.ollama.yml)
#   - LiteLLM proxy:   http://your-litellm/v1
#   - OpenAI direct:   https://api.openai.com/v1  (set LLM_API_KEY too)
INFERENCE_URL=
INFERENCE_API_KEY=
BRAIN_CLASSIFY_MODEL=brain-classify
BRAIN_BRIEF_MODEL=brain-brief

# ===== Optional: vault =====
# Path on host. ./vault is auto-scaffolded by bootstrap.sh. Point at your
# existing Obsidian vault to use real notes.
VAULT_ROOT_HOST=./vault

# ===== Optional: embeddings model =====
LLM_EMBED_MODEL=text-embedding-3-small
LLM_API_BASE=

# ===== Optional: ports (override on collision) =====
# PORT_POSTGRES=5432
# PORT_REDIS=6379
# PORT_EMBEDDINGS=8102
# PORT_BRAIN_API=8103
# PORT_MCP=8104

# ===== Optional =====
LOG_LEVEL=INFO
TICK_INTERVAL_SECONDS=7200
